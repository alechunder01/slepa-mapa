<Window x:Class="it2a_spol_blind_map.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:it2a_spol_blind_map"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>

        <Image Name="MapImage"
           Source="/img/czechia.png"
           Stretch="Uniform"
           SizeChanged="MapImage_SizeChanged"
           MouseDown="MapImage_MouseDown"/>

        <TextBlock x:Name="aktivni" Height="41" Margin="431,11,0,0" Text="Aktivní je xxxxxx" VerticalAlignment="Top" Width="302" FontSize="24"/>
        <Canvas Name="OverlayCanvas"/>

    </Grid>
</Window>
